# ── Production Environment Variables ─────────────────
# Set these in your Railway dashboard (not in a file).
# This file is a reference only.

# ── App ──────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Database (Neon PostgreSQL) ───────────────────────
# Get this from: neon.tech → Project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Auth ─────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# ── CORS / Frontend ─────────────────────────────────
# Update with your actual Vercel domain
CORS_ORIGINS=["https://your-app.vercel.app"]
FRONTEND_URL=https://your-app.vercel.app

# ── OAuth — Google (optional) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — Discord (optional) ───────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── MAL API ──────────────────────────────────────────
MAL_CLIENT_ID=

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_CHAT_TEMPERATURE=0.7
OPENAI_CHAT_MAX_TOKENS=2000

# ── Guardrails ──────────────────────────────────────
RECOMMEND_MAX_ITEMS_PER_REQUEST=10
RECOMMEND_JOB_TIMEOUT_SECONDS=45
LLM_MAX_ESTIMATED_COST_USD=0.03

# ── Vector Store ─────────────────────────────────────
# Railway persistent volume mount point
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_COLLECTION_NAME=anime_catalog
